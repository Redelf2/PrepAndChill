<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — full dark, no action bar -->
    <style name="Theme.PrepAndChill" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen — fullscreen, no system bars -->
    <style name="Theme.PrepAndChill.Splash" parent="Theme.PrepAndChill">
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>