<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">


    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back_arrow"
            android:tint="#F1F5F9"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Setup"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#F1F5F9"
            android:gravity="center"
            android:paddingEnd="32dp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SUBJECT SETUP"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 2 of 4"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#A855F7" />
        </LinearLayout>

        <!-- Progress bar: 2 of 4 = 50% -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_progress_track">

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="@drawable/bg_progress_fill_purple" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>


    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutProgress"
        app:layout_constraintBottom_toTopOf="@id/layoutFooter">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subject &amp; Date Setup"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#A855F7"
                android:layout_marginBottom="8dp" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Personalize your study rhythm for Prep &amp; Chill."
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="24dp" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SELECTED SUBJECTS"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />


            <LinearLayout
                android:id="@+id/subjectRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_subject_item"
                android:padding="17dp"
                android:layout_marginBottom="10dp">

                <View
                    android:id="@+id/checkbox1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_checkbox_checked"
                    android:layout_marginEnd="15dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Advanced Mathematics"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set your Exam Data"
                        android:textSize="12sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#A855F7"
                    android:contentDescription="Calendar" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/subjectRow2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_subject_item"
                android:padding="17dp"
                android:layout_marginBottom="10dp">

                <View
                    android:id="@+id/checkbox2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_checkbox_checked"
                    android:layout_marginEnd="15dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quantum Physics"
                        android:textColor="#F1F5F9"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set your exam date"
                        android:textSize="12sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#A855F7"
                    android:contentDescription="Calendar" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/subjectRow3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_subject_item"
                android:padding="17dp"
                android:layout_marginBottom="10dp"
                android:alpha="0.7">

                <View
                    android:id="@+id/checkbox3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_checkbox_unchecked"
                    android:layout_marginEnd="15dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Organic Chemistry"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No date selected"
                        android:textSize="12sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#475569"
                    android:contentDescription="Calendar" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/subjectRow4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_subject_item"
                android:padding="17dp"
                android:layout_marginBottom="16dp"
                android:alpha="0.7">

                <View
                    android:id="@+id/checkbox4"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_checkbox_unchecked"
                    android:layout_marginEnd="15dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Computer Science"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Default timeline"
                        android:textSize="12sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#475569"
                    android:contentDescription="Calendar" />
            </LinearLayout>

            <!-- Add New Subject -->
            <LinearLayout
                android:id="@+id/btnAddSubject"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_add_subject">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⊕"
                    android:textSize="18sp"
                    android:textColor="#94A3B8"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add New Subject"
                    android:textSize="14sp"
                    android:textColor="#94A3B8" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:id="@+id/layoutFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">


        <TextView
            android:id="@+id/tvSubjectsReady"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 subjects ready"
            android:textSize="14sp"
            android:textColor="#94A3B8"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveContinue"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Save and Continue ›"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_purple_glow"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null"
            app:cornerRadius="12dp"
            app:elevation="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>