<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Step 3 of 4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:layout_gravity="center"/>


        <TextView
            android:text="Knowledge Assessment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:layout_marginTop="16dp"/>


        <ProgressBar
            style="?android:attr/progressBarStyleHorizontal"
            android:progress="75"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:progressTint="@color/accent_purple"/>

        <TextView

            android:text="Assess your expertise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:layout_marginTop="20dp"/>

        <TextView
            android:text="Be honest with your proficiency levels..."
            android:textColor="@color/text_gray"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/card_dark">

            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Advanced Mathematics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"/>

                <TextView
                    android:text="Linear Algebra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_gray"
                    android:layout_marginTop="12dp"/>

                <SeekBar
                    android:id="@+id/seekLinear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="65"/>


                <TextView
                    android:text="Multivariable Calculus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_gray"
                    android:layout_marginTop="12dp"/>

                <SeekBar
                    android:id="@+id/seekMulti"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="42"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <Button
            android:id="@+id/btnGenerate"
            android:text="Generate My Plan"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/text_white"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>

    </LinearLayout>
</ScrollView>