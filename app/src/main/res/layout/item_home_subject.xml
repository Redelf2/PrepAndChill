<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_assessment_card"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageView
        android:id="@+id/ivSubjectIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_social_button"
        android:padding="8dp"
        android:src="@drawable/ic_book_open" />

    <TextView
        android:id="@+id/tvSubjectShortName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="SUB"
        android:textColor="#A855F7"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSubjectFullName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Subject Name"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_clock"
            android:tint="#94A3B8" />

        <TextView
            android:id="@+id/tvSubjectTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="2h 00m"
            android:textColor="#94A3B8"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>