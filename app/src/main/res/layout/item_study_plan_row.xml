<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:background="@drawable/bg_session_card"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subject"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_streak_card"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="1h"
            android:textColor="@color/accent_orange"
            android:textSize="10sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0/0 topics done"
            android:textColor="@color/text_gray"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvSplit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Learn: 20m | Revise: 10m"
            android:textColor="@color/accent_purple"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- AI Insights Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_home_card"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvInsightsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI INSIGHTS"
            android:textColor="@color/accent_orange"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInsights"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="High Urgency • New Learning Focus"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="italic" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@color/bg_black"
            android:alpha="0.3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXT TOPICS"
            android:textColor="@color/text_gray"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNext1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="• Loading…"
            android:textColor="@color/text_white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvNext2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="• "
            android:textColor="@color/text_white"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartSession"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:text="Start Study Session"
        android:textAllCaps="false"
        android:textSize="12sp"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_clock"
        app:iconGravity="textStart"
        app:backgroundTint="@color/accent_orange" />

</LinearLayout>
